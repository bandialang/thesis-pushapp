PORT=3000
TIMEZONE=Asia/Seoul
DAILY_SEND_TIMES=09:00,15:00
PAPER_COUNT=5
LOOKBACK_DAYS=45
NO_REPEAT_DAYS=14
STATE_FILE_PATH=./data/history.json
AUTH_FILE_PATH=./data/auth.json

# Kakao settings
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao/callback
KCI_API_KEY=

# Optional: restrict to your own test user through Kakao's "나에게 보내기" API.
